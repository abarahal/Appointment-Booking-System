{#
 # Email template for appointment modification.
 #
 # Variables:
 #   - appointment: The appointment entity.
 #   - site_name: The site name.
 #   - manage_url: URL to manage the appointment.
 #   - date_label: Formatted date/time string.
 #}
<div style="font-family: Arial, sans-serif; max-width: 600px; margin: 0 auto; padding: 20px;">
  <div style="background: #ffc107; color: #333; padding: 20px; border-radius: 6px 6px 0 0; text-align: center;">
    <h1 style="margin: 0; font-size: 22px;">&#9998; {{ 'Rendez-vous modifié'|t }}</h1>
  </div>

  <div style="border: 1px solid #ddd; border-top: none; padding: 20px; border-radius: 0 0 6px 6px;">
    <p>{{ 'Bonjour'|t }} <strong>{{ appointment.client_name.value }}</strong>,</p>

    <p>{{ 'Votre rendez-vous a été modifié. Voici les nouveaux détails :'|t }}</p>

    <table style="width: 100%; border-collapse: collapse; margin: 15px 0;">
      <tr>
        <td style="padding: 8px; border-bottom: 1px solid #eee; color: #666; width: 40%;">{{ 'Référence'|t }}</td>
        <td style="padding: 8px; border-bottom: 1px solid #eee;"><strong>#{{ appointment.id.value }}</strong></td>
      </tr>
      <tr>
        <td style="padding: 8px; border-bottom: 1px solid #eee; color: #666;">{{ 'Agence'|t }}</td>
        <td style="padding: 8px; border-bottom: 1px solid #eee;">{{ appointment.agency.entity.label }}</td>
      </tr>
      <tr>
        <td style="padding: 8px; border-bottom: 1px solid #eee; color: #666;">{{ 'Conseiller'|t }}</td>
        <td style="padding: 8px; border-bottom: 1px solid #eee;">{{ appointment.adviser_name.value }}</td>
      </tr>
      <tr>
        <td style="padding: 8px; border-bottom: 1px solid #eee; color: #666;">{{ 'Type de rendez-vous'|t }}</td>
        <td style="padding: 8px; border-bottom: 1px solid #eee;">{{ appointment.appointment_type.entity.label }}</td>
      </tr>
      <tr>
        <td style="padding: 8px; border-bottom: 1px solid #eee; color: #666;">{{ 'Nouvelle date et heure'|t }}</td>
        <td style="padding: 8px; border-bottom: 1px solid #eee;"><strong>{{ date_label }}</strong></td>
      </tr>
    </table>

    {% if manage_url %}
    <p style="text-align: center; margin: 25px 0;">
      <a href="{{ manage_url }}" style="background: #ffc107; color: #333; padding: 12px 30px; text-decoration: none; border-radius: 4px; display: inline-block; font-weight: bold;">
        {{ 'Voir mon rendez-vous'|t }}
      </a>
    </p>
    {% endif %}

    <p style="color: #999; font-size: 12px; margin-top: 20px; border-top: 1px solid #eee; padding-top: 15px;">
      {{ 'Ce message a été envoyé automatiquement par'|t }} {{ site_name }}.
    </p>
  </div>
</div>
