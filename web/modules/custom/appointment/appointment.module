<?php

declare(strict_types=1);

/**
 * @file
 * Appointment module hooks.
 */

/**
 * Implements hook_theme().
 */
function appointment_theme(array $existing, string $type, string $theme, string $path): array
{
    return [
        'appointment_confirmation' => [
            'variables' => [
                'appointment' => NULL,
                'edit_url' => NULL,
                'cancel_url' => NULL,
            ],
            'template' => 'appointment-confirmation',
        ],
        'appointment_list' => [
            'variables' => [
                'rows' => [],
                'filters' => [],
                'lookup_url' => NULL,
            ],
            'template' => 'appointment-list',
        ],
        'appointment_email_confirmation' => [
            'variables' => [
                'appointment' => NULL,
                'site_name' => NULL,
                'manage_url' => NULL,
                'date_label' => NULL,
            ],
            'template' => 'email/appointment-email-confirmation',
        ],
        'appointment_email_modification' => [
            'variables' => [
                'appointment' => NULL,
                'site_name' => NULL,
                'manage_url' => NULL,
                'date_label' => NULL,
            ],
            'template' => 'email/appointment-email-modification',
        ],
        'appointment_email_cancellation' => [
            'variables' => [
                'appointment' => NULL,
                'site_name' => NULL,
                'manage_url' => NULL,
                'date_label' => NULL,
            ],
            'template' => 'email/appointment-email-cancellation',
        ],
        'appointment_email_reminder' => [
            'variables' => [
                'appointment' => NULL,
                'site_name' => NULL,
                'manage_url' => NULL,
                'date_label' => NULL,
                'hours_until' => NULL,
            ],
            'template' => 'email/appointment-email-reminder',
        ],
    ];
}

/**
 * Implements hook_page_attachments().
 */
function appointment_page_attachments(array &$attachments): void {}

/**
 * Implements hook_mail().
 */
function appointment_mail(string $key, array &$message, array $params): void
{
    /** @var \Drupal\appointment\Entity\AppointmentEntity|null $appointment */
    $appointment = $params['appointment'] ?? NULL;
    if (!$appointment) {
        return;
    }

    $t = \Drupal::translation();
    $site_name = \Drupal::config('system.site')->get('name') ?: 'ScheduleHub';
    $date_label = \Drupal::service('date.formatter')->format(
        (int) $appointment->get('start_time')->value,
        'custom',
        'd/m/Y \à H:i'
    );
    $manage_url = $params['manage_link'] ?? '/appointment/' . $appointment->id() . '/confirmation';

    $subject_map = [
        'confirmation' => (string) $t->translate('Rendez-vous confirmé - @site', ['@site' => $site_name]),
        'modification' => (string) $t->translate('Rendez-vous modifié - @site', ['@site' => $site_name]),
        'cancellation' => (string) $t->translate('Rendez-vous annulé - @site', ['@site' => $site_name]),
        'reminder'     => (string) $t->translate('Rappel de rendez-vous - @site', ['@site' => $site_name]),
    ];

    $theme_map = [
        'confirmation' => 'appointment_email_confirmation',
        'modification' => 'appointment_email_modification',
        'cancellation' => 'appointment_email_cancellation',
        'reminder'     => 'appointment_email_reminder',
    ];

    $message['subject'] = $subject_map[$key] ?? (string) $t->translate('Mise à jour du rendez-vous');

    // Render the HTML template.
    $theme_hook = $theme_map[$key] ?? NULL;
    if ($theme_hook) {
        $build = [
            '#theme' => $theme_hook,
            '#appointment' => $appointment,
            '#site_name' => $site_name,
            '#manage_url' => $manage_url,
            '#date_label' => $date_label,
        ];
        if ($key === 'reminder' && isset($params['hours_until'])) {
            $build['#hours_until'] = $params['hours_until'];
        }
        /** @var \Drupal\Core\Render\RendererInterface $renderer */
        $renderer = \Drupal::service('renderer');
        $html = (string) $renderer->renderPlain($build);
        $message['body'][] = $html;
        $message['headers']['Content-Type'] = 'text/html; charset=UTF-8';
    } else {
        $message['body'][] = (string) $t->translate('Votre rendez-vous a été mis à jour.');
    }
}

/**
 * Implements hook_cron().
 *
 * Queues reminder emails for upcoming appointments.
 */
function appointment_cron(): void
{
    $config = \Drupal::config('appointment.settings');
    $hours_before = (int) ($config->get('reminder_hours_before') ?? 24);
    if ($hours_before <= 0) {
        return;
    }

    $now = \Drupal::time()->getRequestTime();
    $reminder_window = $now + ($hours_before * 3600);

    // Find booked/confirmed appointments within the reminder window
    // that haven't had a reminder sent yet.
    $ids = \Drupal::entityQuery('appointment')
        ->accessCheck(FALSE)
        ->condition('status', ['pending', 'confirmed'], 'IN')
        ->condition('start_time', $now, '>')
        ->condition('start_time', $reminder_window, '<=')
        ->condition('reminder_sent', 0)
        ->execute();

    if (empty($ids)) {
        return;
    }

    /** @var \Drupal\appointment\Service\EmailService $email_service */
    $email_service = \Drupal::service('appointment.email_service');

    $appointments = \Drupal::entityTypeManager()
        ->getStorage('appointment')
        ->loadMultiple($ids);

    foreach ($appointments as $appointment) {
        /** @var \Drupal\appointment\Entity\AppointmentEntity $appointment */
        $start = (int) $appointment->get('start_time')->value;
        $hours_until = max(1, (int) round(($start - $now) / 3600));

        $email_service->queueAppointmentEmail(
            (int) $appointment->id(),
            'reminder',
            ['hours_until' => $hours_until],
        );

        // Mark reminder as sent to avoid duplicates.
        $appointment->set('reminder_sent', TRUE);
        $appointment->save();
    }

    \Drupal::logger('appointment')->info('Queued @count reminder emails.', [
        '@count' => count($ids),
    ]);

    // Soft-delete appointments older than one week.
    $one_week_ago = $now - (7 * 86400);
    $expired_ids = \Drupal::entityQuery('appointment')
        ->accessCheck(FALSE)
        ->condition('deleted', 0)
        ->condition('start_time', $one_week_ago, '<')
        ->execute();

    if (!empty($expired_ids)) {
        $expired = \Drupal::entityTypeManager()
            ->getStorage('appointment')
            ->loadMultiple($expired_ids);

        foreach ($expired as $appt) {
            /** @var \Drupal\appointment\Entity\AppointmentEntity $appt */
            $appt->softDelete();
        }

        \Drupal::logger('appointment')->info('Soft-deleted @count expired appointments (older than 1 week).', [
            '@count' => count($expired_ids),
        ]);
    }
}
